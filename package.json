{
  "name": "threadts-universal",
  "version": "1.0.2",
  "type": "module",
  "description": "Universal TypeScript library for effortless parallel computing across all JavaScript ecosystems",
  "main": "dist/index.cjs",
  "module": "dist/esm/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/**/*",
    "src/**/*"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:ci": "vitest run --pool=forks --poolOptions.forks.singleFork=true",
    "test:local": "vitest run --expose-gc",
    "test:browser": "playwright test",
    "test:node": "bun run test:node:ci",
    "test:node:ci": "vitest run --testNamePattern=node",
    "test:node:local": "vitest run --expose-gc --testNamePattern=node",
    "test:memory": "bun run test:memory:ci",
    "test:memory:ci": "vitest run tests/memory-leaks.test.ts",
    "test:memory:local": "vitest run --expose-gc tests/memory-leaks.test.ts",
    "test:all": "bun run test && bun run test:browser && bun run test:memory",
    "test:pack": "vitest run --exclude=**/memory-leaks.test.ts --exclude=**/browser/**",
    "test:package": "node test-package.cjs",
    "benchmark": "bun run benchmarks/core.ts",
    "benchmark:memory": "bun run benchmarks/advanced.ts",
    "benchmark:scenarios": "bun run benchmarks/scenarios.ts",
    "benchmark:advanced": "bun run benchmarks/advanced-scenarios.ts",
    "benchmark:all": "bun run benchmark && bun run benchmark:memory && bun run benchmark:scenarios && bun run benchmark:advanced",
    "deps:check": "bun run scripts/dependency-manager.ts",
    "deps:update": "bun update && bun run deps:check",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "docs": "typedoc",
    "docs:generate": "bun run docs && bun run docs:api",
    "docs:api": "typedoc src --out docs/api --excludePrivate --excludeProtected",
    "prepare": "bun run build",
    "prepack": "bun run build && bun run test:pack && bun run test:package",
    "postversion": "git push --follow-tags",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major",
    "health:check": "bun run test:all && bun run benchmark:all && bun run deps:check"
  },
  "keywords": [
    "parallel",
    "worker",
    "threads",
    "typescript",
    "universal",
    "performance",
    "async",
    "concurrency",
    "browser",
    "nodejs",
    "deno",
    "bun"
  ],
  "author": "ThreadTS Universal Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JosunLP/ThreadTS-Universal.git"
  },
  "bugs": {
    "url": "https://github.com/JosunLP/ThreadTS-Universal/issues"
  },
  "homepage": "https://threadts.dev",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.1.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "typedoc": "^0.28.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=22.13.0",
    "bun": ">=1.3.11"
  },
  "packageManager": "bun@1.3.11",
  "browser": {
    "./dist/node.js": false,
    "./src/adapters/node.ts": false
  }
}
